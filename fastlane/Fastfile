opt_out_usage

default_platform(:ios)

platform :ios do
  desc "Upload screenshots and metadata to App Store Connect (fastlane 2.234+)"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    version = ENV["ASC_APP_VERSION"]
    UI.user_error!("Set ASC_APP_VERSION (run: eval \"$(python3 scripts/asc-ensure-draft-version.py | grep '^export ')\")") unless version && !version.empty?

    skip_shots = ENV.fetch("SKIP_SCREENSHOTS", "false") == "true"

    deliver(
      api_key: api_key,
      app_version: version,
      skip_app_version_update: true,
      force: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      version_check_wait_retry_limit: 7,
      skip_binary_upload: true,
      skip_screenshots: skip_shots,
      overwrite_screenshots: !skip_shots,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Upload metadata + screenshots, select build, and submit 1.2.4 for review"
  lane :ship_review do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    version = ENV["ASC_APP_VERSION"]
    UI.user_error!("Set ASC_APP_VERSION") unless version && !version.empty?
    build_number = ENV["ASC_BUILD_NUMBER"]
    UI.user_error!("Set ASC_BUILD_NUMBER") unless build_number && !build_number.empty?

    deliver(
      api_key: api_key,
      app_version: version,
      build_number: build_number,
      skip_app_version_update: false,
      force: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      version_check_wait_retry_limit: 7,
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false
      }
    )
  end
end
